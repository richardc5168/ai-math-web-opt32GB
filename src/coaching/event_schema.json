{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIMath Coach Event Log v1",
  "description": "Local event log schema for Coach Mode. Stored in localStorage.",
  "type": "object",
  "required": ["version", "user_id", "events"],
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "user_id": { "type": "string", "minLength": 1 },
    "events": {
      "type": "array",
      "items": { "$ref": "#/definitions/event" }
    }
  },
  "definitions": {
    "event": {
      "type": "object",
      "required": ["type", "ts_ms"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "attempt_started",
            "hint_shown",
            "answer_submitted",
            "attempt_completed",
            "next_question"
          ]
        },
        "ts_ms": { "type": "integer", "minimum": 0 },
        "unit": { "type": "string" },
        "app_id": { "type": "string" },
        "question_id": { "type": ["string", "null"] },
        "hint_level": { "type": "number" },
        "correct": { "type": "boolean" },
        "allow_continue": { "type": "boolean" },
        "payload": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
