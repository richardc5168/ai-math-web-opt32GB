#!/bin/sh
# Pre-commit hook (git core.hooksPath=.githooks)
# Runs the repo's strict pre-commit framework checks.

VENV_PY="./.venv/Scripts/python.exe"

if [ -x "$VENV_PY" ]; then
  "$VENV_PY" -m pre_commit run --hook-stage pre-commit
  status=$?
else
  python -m pre_commit run --hook-stage pre-commit
  status=$?
fi

if [ $status -ne 0 ]; then
  echo "[pre-commit] Checks failed. Commit aborted." 1>&2
  exit $status
fi

exit 0
