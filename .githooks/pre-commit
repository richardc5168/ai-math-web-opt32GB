#!/bin/sh
# Pre-commit hook: enforce verification before commit

/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify_before_commit.ps1
status=$?
if [ $status -ne 0 ]; then
  echo "[pre-commit] Verification failed. Commit aborted." 1>&2
  exit $status
fi

exit 0
