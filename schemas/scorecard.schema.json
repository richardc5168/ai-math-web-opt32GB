{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "tests", "lighthouse", "axe", "hint_rubric", "golden", "timestamp"],
  "properties": {
    "version": { "type": "string" },
    "timestamp": { "type": "string" },
    "tests": {
      "type": "object",
      "required": ["pass"],
      "properties": {
        "pass": { "type": "boolean" }
      }
    },
    "lighthouse": {
      "type": "object",
      "required": ["performance", "accessibility"],
      "properties": {
        "performance": { "type": "number" },
        "accessibility": { "type": "number" }
      }
    },
    "axe": {
      "type": "object",
      "required": ["critical"],
      "properties": {
        "critical": { "type": "integer" }
      }
    },
    "hint_rubric": {
      "type": "object",
      "required": ["avg"],
      "properties": {
        "avg": { "type": "number" }
      }
    },
    "golden": {
      "type": "object",
      "required": ["correct_rate"],
      "properties": {
        "correct_rate": { "type": "number" }
      }
    }
  }
}
