{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "topic",
    "prompt",
    "answer",
    "common_wrong_answers",
    "hint_ladder",
    "report_expectations"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "topic": { "type": "string", "minLength": 2 },
    "prompt": { "type": "string", "minLength": 5 },
    "answer": { "type": "string", "minLength": 1 },
    "common_wrong_answers": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "hint_ladder": {
      "type": "object",
      "required": ["h1_strategy", "h2_equation", "h3_compute", "h4_check_reflect"],
      "properties": {
        "h1_strategy": { "type": "string", "minLength": 5 },
        "h2_equation": { "type": "string", "minLength": 5 },
        "h3_compute": { "type": "string", "minLength": 5 },
        "h4_check_reflect": { "type": "string", "minLength": 5 }
      }
    },
    "report_expectations": {
      "type": "object",
      "required": ["skill_tags", "misconceptions"],
      "properties": {
        "skill_tags": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "misconceptions": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
